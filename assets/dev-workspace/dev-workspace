#!/bin/bash
export PATH="/opt/homebrew/bin:/Users/bytedance/.local/bin:$PATH"

PROJECTS_FILE="$HOME/.config/dev-workspace/projects"

# --- 解析项目注册表（兼容 bash 3）---
NAMES=()
PROJ_PATHS=()

while IFS='=' read -r name path; do
  [[ -z "$name" || "$name" == \#* ]] && continue
  expanded=$(eval echo "$path")
  NAMES+=("$name")
  PROJ_PATHS+=("$expanded")
done < "$PROJECTS_FILE"

# --- 通过别名查找路径 ---
find_project() {
  local key="$1"
  for i in "${!NAMES[@]}"; do
    if [[ "${NAMES[$i]}" == "$key" ]]; then
      echo "${PROJ_PATHS[$i]}"
      return 0
    fi
  done
  return 1
}

# --- 选择项目 ---
if [[ -n "$1" ]]; then
  matched=$(find_project "$1")
  if [[ -n "$matched" ]]; then
    PROJECT="$matched"
    SESSION="$1"
  elif [[ -d "$1" ]]; then
    PROJECT="$1"
    SESSION=$(basename "$1")
  else
    echo "未知项目: $1"
    echo "可用项目: ${NAMES[*]}"
    exit 1
  fi
else
  echo "选择项目:"
  echo ""
  for i in "${!NAMES[@]}"; do
    printf "  %d) %-20s %s\n" $((i+1)) "${NAMES[$i]}" "${PROJ_PATHS[$i]}"
  done
  CUSTOM_NUM=$(( ${#NAMES[@]} + 1 ))
  TERM_NUM=$(( ${#NAMES[@]} + 2 ))
  printf "  %d) %-20s %s\n" "$CUSTOM_NUM" "custom" "输入自定义路径..."
  printf "  %d) %-20s %s\n" "$TERM_NUM" "terminal" "打开空白终端"
  echo ""
  read -rp "输入编号或项目名: " choice

  if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice == TERM_NUM )) || [[ "$choice" == "terminal" ]]; then
    SESSION="terminal-$$"
    tmux new-session -d -s "$SESSION" -c "$HOME"
    exec tmux attach -t "$SESSION"
  elif [[ "$choice" =~ ^[0-9]+$ ]] && (( choice == CUSTOM_NUM )); then
    read -rp "输入项目路径: " custom_path
    custom_path=$(eval echo "$custom_path")
    if [[ ! -d "$custom_path" ]]; then
      echo "路径不存在: $custom_path"
      exit 1
    fi
    PROJECT="$custom_path"
    SESSION=$(basename "$custom_path")
  elif [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#NAMES[@]} )); then
    idx=$((choice-1))
    SESSION="${NAMES[$idx]}"
    PROJECT="${PROJ_PATHS[$idx]}"
  else
    matched=$(find_project "$choice")
    if [[ -n "$matched" ]]; then
      SESSION="$choice"
      PROJECT="$matched"
    else
      echo "无效选择"
      exit 1
    fi
  fi
fi

# --- 选择 AI 工具布局 ---
# ┌───────────┬─────────────────┐
# │ 1 lazygit │ 4 AI_RT (右上)  │
# ├───┬───────┼─────────────────┤
# │2  │3      │ 5 AI_RB (右下)  │
# │yaz│ AI_LB │                 │
# └───┴───────┴─────────────────┘

# 列出该项目已有的 session
EXISTING=$(tmux list-sessions -F '#S' 2>/dev/null | grep "^${SESSION}" || true)
if [[ -n "$EXISTING" ]]; then
  echo ""
  echo "已有 session: $EXISTING"
fi

echo ""
echo "选择 AI 工具布局:"
echo ""
printf "     %-4s %-8s %-8s %-8s\n" "" "左下" "右上" "右下"
echo "  ─────────────────────────────────"
printf "  %s) %-8s %-8s %-8s  %s\n" \
  "0" "—"      "—"      "—"      "[空白终端]" \
  "1" "codex"  "claude" "claude" "[默认]" \
  "2" "claude" "claude" "claude" "" \
  "3" "claude" "codex"  "codex"  "" \
  "4" "codex"  "codex"  "codex"  "" \
  "5" "claude" "claude" "codex"  "" \
  "6" "claude" "codex"  "claude" "" \
  "7" "codex"  "claude" "codex"  "" \
  "8" "codex"  "codex"  "claude" ""
echo ""
read -rp "输入编号 [默认 1]: " ai_choice
ai_choice=${ai_choice:-1}

# Session 名 = 项目名-布局编号（同项目不同布局可并存）
SESSION="${SESSION}-${ai_choice}"

# 如果该组合的 session 已存在，直接 attach
tmux has-session -t "$SESSION" 2>/dev/null && exec tmux attach -t "$SESSION"

# --- 布局 0: 纯空白终端，不分屏 ---
if [[ "$ai_choice" == "0" ]]; then
  tmux new-session -d -s "$SESSION" -c "$PROJECT"
  exec tmux attach -t "$SESSION"
fi

# --- 布局 1-8: 五面板 + AI 工具 ---
case "$ai_choice" in
  1) AI_LB="codex";  AI_RT="claude"; AI_RB="claude" ;;
  2) AI_LB="claude"; AI_RT="claude"; AI_RB="claude" ;;
  3) AI_LB="claude"; AI_RT="codex";  AI_RB="codex"  ;;
  4) AI_LB="codex";  AI_RT="codex";  AI_RB="codex"  ;;
  5) AI_LB="claude"; AI_RT="claude"; AI_RB="codex"  ;;
  6) AI_LB="claude"; AI_RT="codex";  AI_RB="claude" ;;
  7) AI_LB="codex";  AI_RT="claude"; AI_RB="codex"  ;;
  8) AI_LB="codex";  AI_RT="codex";  AI_RB="claude" ;;
  *) AI_LB="codex";  AI_RT="claude"; AI_RB="claude" ;;
esac

# Use pane IDs (-P -F) to avoid index renumbering issues after splits
PANE_LG=$(tmux new-session -d -s "$SESSION" -c "$PROJECT" -P -F '#{pane_id}')
PANE_RT=$(tmux split-window -h -t "$PANE_LG" -c "$PROJECT" -p 55 -P -F '#{pane_id}')
PANE_RB=$(tmux split-window -v -t "$PANE_RT" -c "$PROJECT" -p 50 -P -F '#{pane_id}')
PANE_LB=$(tmux split-window -v -t "$PANE_LG" -c "$PROJECT" -p 35 -P -F '#{pane_id}')
PANE_AILB=$(tmux split-window -h -t "$PANE_LB" -c "$PROJECT" -p 47 -P -F '#{pane_id}')
# PANE_LB = left 53% (yazi), PANE_AILB = right 47% (AI_LB)

sleep 1

# Lock layout proportions (override tmux default scaling)
"$HOME/.config/dev-workspace/reset-layout.sh" "$SESSION"

tmux send-keys -t "$PANE_LG" "lazygit" C-m
tmux send-keys -t "$PANE_LB" "yazi" C-m
# Map tool name to actual launch command
ai_cmd() {
  case "$1" in
    codex)  echo "codex --full-auto" ;;
    claude) echo "claude --enable-auto-mode" ;;
  esac
}

tmux send-keys -t "$PANE_AILB" "$(ai_cmd "$AI_LB")" C-m
tmux send-keys -t "$PANE_RT" "$(ai_cmd "$AI_RT")" C-m
tmux send-keys -t "$PANE_RB" "$(ai_cmd "$AI_RB")" C-m

tmux select-pane -t "$PANE_RT"

exec tmux attach -t "$SESSION"
